# ─── Ambiente ───────────────────────────────────────────
ENV=development

# ─── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=lume
POSTGRES_USER=lume_user
POSTGRES_PASSWORD=troque_esta_senha

# ─── Grafana ────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=troque_esta_senha

# ─── LLM ────────────────────────────────────────────────
# Escolha um provedor e preencha apenas a chave correspondente
OPENAI_API_KEY=
GEMINI_API_KEY=

# ─── E-mail (Brevo SMTP) ────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@lume.com.br